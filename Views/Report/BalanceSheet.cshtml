@model DanialNetAccount.ViewModels.BalanceSheetReport

@{
    ViewData["Title"] = "Balance Sheet";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Statement of Financial Position</h1>
    <span class="text-sm text-gray-500 font-bold uppercase tracking-widest bg-gray-100 px-4 py-2 rounded-full">
        Balance Sheet
    </span>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
    <!-- Assets Side -->
    <div class="space-y-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 bg-green-50 border-b border-green-100 flex justify-between items-center">
                <h2 class="text-xl font-bold text-green-800 uppercase tracking-widest">Assets</h2>
                <div class="p-2 bg-green-100 rounded-lg text-green-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </div>
            <div class="p-8">
                <table class="w-full">
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var line in Model.AssetLines)
                        {
                            <tr class="hover:bg-gray-50/50 transition">
                                <td class="py-4 text-gray-700 font-medium">@line.AccountName</td>
                                <td class="py-4 text-right font-mono font-bold text-gray-900">@line.Balance.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="border-t-2 border-green-100">
                            <td class="py-6 text-lg font-bold text-gray-900">Total Assets</td>
                            <td class="py-6 text-right text-xl font-black text-green-600 font-mono">@Model.TotalAssets.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Liabilities & Equity Side -->
    <div class="space-y-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 bg-red-50 border-b border-red-100 flex justify-between items-center">
                <h2 class="text-xl font-bold text-red-800 uppercase tracking-widest">Liabilities</h2>
            </div>
            <div class="p-8">
                <table class="w-full">
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var line in Model.LiabilityLines)
                        {
                            <tr class="hover:bg-gray-50/50 transition">
                                <td class="py-4 text-gray-700 font-medium">@line.AccountName</td>
                                <td class="py-4 text-right font-mono font-bold text-gray-900">@line.Balance.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="border-t-2 border-red-100">
                            <td class="py-6 text-lg font-bold text-gray-900">Total Liabilities</td>
                            <td class="py-6 text-right text-xl font-black text-red-600 font-mono">@Model.TotalLiabilities.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-8 py-6 bg-purple-50 border-b border-purple-100 flex justify-between items-center">
                <h2 class="text-xl font-bold text-purple-800 uppercase tracking-widest">Equity</h2>
            </div>
            <div class="p-8">
                <table class="w-full">
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var line in Model.EquityLines)
                        {
                            <tr class="hover:bg-gray-50/50 transition">
                                <td class="py-4 text-gray-700 font-medium">@line.AccountName</td>
                                <td class="py-4 text-right font-mono font-bold text-gray-900">@line.Balance.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="border-t-2 border-purple-100">
                            <td class="py-6 text-lg font-bold text-gray-900">Total Equity</td>
                            <td class="py-6 text-right text-xl font-black text-purple-600 font-mono">@Model.TotalEquity.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Grand Total Liabilities & Equity -->
        <div class="bg-gray-900 rounded-2xl p-8 flex justify-between items-center text-white shadow-lg">
            <div>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-[0.2em] mb-1">Combined</p>
                <h3 class="text-lg font-bold">Total Liab. & Equity</h3>
            </div>
            <div class="text-3xl font-black font-mono">
                @Model.TotalLiabilitiesAndEquity.ToString("N2")
            </div>
        </div>
    </div>
</div>

@if (Math.Abs(Model.TotalAssets - Model.TotalLiabilitiesAndEquity) > 0.01m)
{
    <div class="mt-8 bg-red-600 text-white p-6 rounded-2xl shadow-lg animate-pulse flex items-center justify-between">
        <div class="flex items-center">
            <svg class="w-8 h-8 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            <div>
                <h4 class="text-lg font-bold uppercase tracking-widest">Accounting Discrepancy</h4>
                <p class="text-red-100">The Balance Sheet is not balanced. Out of sync by @((Model.TotalAssets - Model.TotalLiabilitiesAndEquity).ToString("N2"))</p>
            </div>
        </div>
        <div class="text-2xl font-mono opacity-50">ERROR</div>
    </div>
}
