@using DanialNetAccount.Services
@inject LocalizationService Loc
@model DanialNetAccount.ViewModels.JournalEntryViewModel

@{
    ViewData["Title"] = Loc.Translate("New Journal Entry");
    var accounts = ViewBag.Accounts as List<DanialNetAccount.Models.Account>;
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">@Loc.Translate("New Journal Entry")</h1>

    <form asp-action="Create" id="journalForm" class="bg-white shadow-sm border border-gray-100 rounded-xl p-8">
        <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-700 p-4 rounded-lg mb-6 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="md:col-span-1">
                <label class="block text-sm font-medium text-gray-700 mb-2">@Loc.Translate("Date")</label>
                <input asp-for="Date" class="block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2.5 px-4 bg-gray-50 border" type="date" />
            </div>
            <div class="md:col-span-2">
                <label class="block text-sm font-medium text-gray-700 mb-2">@Loc.Translate("Description")</label>
                <input asp-for="Description" class="block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2.5 px-4 bg-gray-50 border" placeholder="@Loc.Translate("Entry purpose")..." />
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full mb-6" id="linesTable">
                <thead>
                    <tr class="text-left text-sm font-semibold text-gray-500 border-b border-gray-100">
                        <th class="pb-4 w-1/2">@Loc.Translate("Account")</th>
                        <th class="pb-4 text-right">@Loc.Translate("Debit")</th>
                        <th class="pb-4 text-right">@Loc.Translate("Credit")</th>
                        <th class="pb-4"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @for (int i = 0; i < Model.Lines.Count; i++)
                    {
                        <tr class="line-row">
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")">
                                <select name="Lines[@i].AccountId" class="block w-full border-gray-300 rounded-lg py-2 bg-gray-50 border">
                                    @foreach (var acc in accounts!)
                                    {
                                        <option value="@acc.Id">@acc.Name (@acc.Code)</option>
                                    }
                                </select>
                            </td>
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Lines[@i].Debit" class="block w-full border-gray-300 rounded-lg py-2 debit-input text-right font-mono bg-gray-50 border" value="@Model.Lines[i].Debit" type="number" step="0.01" /></td>
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Lines[@i].Credit" class="block w-full border-gray-300 rounded-lg py-2 credit-input text-right font-mono bg-gray-50 border" value="@Model.Lines[i].Credit" type="number" step="0.01" /></td>
                            <td class="py-4"><button type="button" class="text-red-500 hover:text-red-700 transition remove-line"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="bg-gray-50 font-bold border-t border-gray-200">
                        <td class="px-4 py-4 text-center">@Loc.Translate("Total")</td>
                        <td class="px-4 py-4 text-right font-mono" id="totalDebit">0.00</td>
                        <td class="px-4 py-4 text-right font-mono" id="totalCredit">0.00</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="flex justify-between items-center">
            <button type="button" id="addLine" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-6 rounded-lg transition flex items-center">
                <svg class="w-5 h-5 @(Loc.GetDirection() == "rtl" ? "ml-2" : "mr-2")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                @Loc.Translate("Add Row")
            </button>
            <div class="space-x-3 @(Loc.GetDirection() == "rtl" ? "space-x-reverse" : "")">
                <a asp-action="Index" class="text-gray-500 hover:text-gray-700 font-medium">@Loc.Translate("Cancel")</a>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-10 rounded-lg shadow-lg transition">@Loc.Translate("Post Entry")</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let accounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(accounts?.Select(a => new { a.Id, a.Name, a.Code })));

            function updateTotals() {
                let totalDebit = 0;
                let totalCredit = 0;
                $('.debit-input').each(function () {
                    totalDebit += parseFloat($(this).val()) || 0;
                });
                $('.credit-input').each(function () {
                    totalCredit += parseFloat($(this).val()) || 0;
                });
                $('#totalDebit').text(totalDebit.toLocaleString(undefined, {minimumFractionDigits: 2}));
                $('#totalCredit').text(totalCredit.toLocaleString(undefined, {minimumFractionDigits: 2}));

                if (Math.abs(totalDebit - totalCredit) > 0.01 || totalDebit === 0) {
                    $('#totalDebit, #totalCredit').addClass('text-red-600').removeClass('text-green-600');
                } else {
                    $('#totalDebit, #totalCredit').addClass('text-green-600').removeClass('text-red-600');
                }
            }

            $('#addLine').click(function () {
                let index = $('#linesTable tbody tr').length;
                let options = accounts.map(a => `<option value="${a.Id}">${a.Name} (${a.Code})</option>`).join('');
                let row = `
                    <tr class="line-row">
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")">
                            <select name="Lines[${index}].AccountId" class="block w-full border-gray-300 rounded-lg py-2 bg-gray-50 border">
                                ${options}
                            </select>
                        </td>
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Lines[${index}].Debit" class="block w-full border-gray-300 rounded-lg py-2 debit-input text-right font-mono bg-gray-50 border" value="0" type="number" step="0.01" /></td>
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Lines[${index}].Credit" class="block w-full border-gray-300 rounded-lg py-2 credit-input text-right font-mono bg-gray-50 border" value="0" type="number" step="0.01" /></td>
                        <td class="py-4"><button type="button" class="text-red-500 hover:text-red-700 transition remove-line"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                    </tr>`;
                $('#linesTable tbody').append(row);
                updateTotals();
            });

            $(document).on('click', '.remove-line', function () {
                $(this).closest('tr').remove();
                reindexLines();
                updateTotals();
            });

            $(document).on('input', '.debit-input, .credit-input', function () {
                updateTotals();
            });

            function reindexLines() {
                $('#linesTable tbody tr').each(function (index) {
                    $(this).find('select').attr('name', `Lines[${index}].AccountId`);
                    $(this).find('.debit-input').attr('name', `Lines[${index}].Debit`);
                    $(this).find('.credit-input').attr('name', `Lines[${index}].Credit`);
                });
            }

            if($('#linesTable tbody tr').length === 0) {
                $('#addLine').click();
                $('#addLine').click();
            }
            updateTotals();
        });
    </script>
}
