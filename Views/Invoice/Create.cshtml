@model DanialNetAccount.ViewModels.InvoiceViewModel

@{
    ViewData["Title"] = "Create Invoice";
    var products = ViewBag.Products as List<DanialNetAccount.Models.Product>;
}

<h1>Create Invoice</h1>

<form asp-action="Create" id="invoiceForm">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="CustomerName" class="form-label">Customer Name</label>
            <input asp-for="CustomerName" class="form-control" />
        </div>
        <div class="col-md-6">
            <label asp-for="Date" class="form-label">Date</label>
            <input asp-for="Date" class="form-control" type="date" />
        </div>
    </div>

    <h3>Items</h3>
    <table class="table" id="itemsTable">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>
                        <select name="Items[@i].ProductId" class="form-control product-select">
                            @foreach (var p in products!)
                            {
                                <option value="@p.Id" data-price="@p.Price">@p.Name</option>
                            }
                        </select>
                    </td>
                    <td><input name="Items[@i].Quantity" class="form-control quantity-input" value="@Model.Items[i].Quantity" type="number" /></td>
                    <td><input name="Items[@i].UnitPrice" class="form-control price-input" value="@Model.Items[i].UnitPrice" type="number" step="0.01" /></td>
                    <td class="item-total">0.00</td>
                    <td><button type="button" class="btn btn-danger remove-item">Remove</button></td>
                </tr>
            }
        </tbody>
    </table>

    <button type="button" id="addItem" class="btn btn-secondary mb-3">Add Item</button>

    <div class="row justify-content-end">
        <div class="col-md-4">
            <ul class="list-group">
                <li class="list-group-item d-flex justify-content-between">
                    <span>Subtotal:</span>
                    <span id="subtotal">0.00</span>
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span>Tax (9%):</span>
                    <span id="tax">0.00</span>
                </li>
                <li class="list-group-item d-flex justify-content-between font-weight-bold">
                    <strong>Total:</strong>
                    <strong id="finalTotal">0.00</strong>
                </li>
            </ul>
        </div>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Generate Invoice" class="btn btn-success" />
        <a asp-action="Index" class="btn btn-link">Back to List</a>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            let products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products?.Select(p => new { p.Id, p.Name, p.Price })));

            function calculateTotals() {
                let subtotal = 0;
                $('#itemsTable tbody tr').each(function () {
                    let qty = parseFloat($(this).find('.quantity-input').val()) || 0;
                    let price = parseFloat($(this).find('.price-input').val()) || 0;
                    let total = qty * price;
                    $(this).find('.item-total').text(total.toFixed(2));
                    subtotal += total;
                });

                let tax = subtotal * 0.09;
                let finalTotal = subtotal + tax;

                $('#subtotal').text(subtotal.toFixed(2));
                $('#tax').text(tax.toFixed(2));
                $('#finalTotal').text(finalTotal.toFixed(2));
            }

            $('#addItem').click(function () {
                let index = $('#itemsTable tbody tr').length;
                let options = products.map(p => `<option value="${p.Id}" data-price="${p.Price}">${p.Name}</option>`).join('');
                let row = `
                    <tr>
                        <td>
                            <select name="Items[${index}].ProductId" class="form-control product-select">
                                ${options}
                            </select>
                        </td>
                        <td><input name="Items[${index}].Quantity" class="form-control quantity-input" value="1" type="number" /></td>
                        <td><input name="Items[${index}].UnitPrice" class="form-control price-input" value="${products[0]?.Price || 0}" type="number" step="0.01" /></td>
                        <td class="item-total">0.00</td>
                        <td><button type="button" class="btn btn-danger remove-item">Remove</button></td>
                    </tr>`;
                $('#itemsTable tbody').append(row);
                calculateTotals();
            });

            $(document).on('click', '.remove-item', function () {
                $(this).closest('tr').remove();
                reindexItems();
                calculateTotals();
            });

            $(document).on('change', '.product-select', function() {
                let price = $(this).find(':selected').data('price');
                $(this).closest('tr').find('.price-input').val(price);
                calculateTotals();
            });

            $(document).on('input', '.quantity-input, .price-input', function () {
                calculateTotals();
            });

            function reindexItems() {
                $('#itemsTable tbody tr').each(function (index) {
                    $(this).find('.product-select').attr('name', `Items[${index}].ProductId`);
                    $(this).find('.quantity-input').attr('name', `Items[${index}].Quantity`);
                    $(this).find('.price-input').attr('name', `Items[${index}].UnitPrice`);
                });
            }

            if($('#itemsTable tbody tr').length === 0) {
                $('#addItem').click();
            }
            calculateTotals();
        });
    </script>
}
