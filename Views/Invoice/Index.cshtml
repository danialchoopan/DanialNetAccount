@model IEnumerable<DanialNetAccount.Models.Invoice>

@{
    ViewData["Title"] = "Invoices";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Invoices</h1>
    <a asp-action="Create" class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-6 rounded-lg shadow-sm transition flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        New Invoice
    </a>
</div>

<div class="bg-white shadow-sm border border-gray-100 rounded-xl overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-gray-50 border-b border-gray-100">
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">Number</th>
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">Date</th>
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">Customer</th>
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider text-right">Amount</th>
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider text-center">Status</th>
                <th class="px-6 py-4 text-sm font-semibold text-gray-600 uppercase tracking-wider"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var invoice in Model)
            {
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4 font-mono text-sm text-gray-600">@invoice.InvoiceNumber</td>
                    <td class="px-6 py-4 text-gray-700">@invoice.Date.ToShortDateString()</td>
                    <td class="px-6 py-4 font-medium text-gray-900">@invoice.CustomerName</td>
                    <td class="px-6 py-4 text-right font-bold text-gray-900 font-mono">@invoice.FinalAmount.ToString("N2")</td>
                    <td class="px-6 py-4 text-center">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                            @(invoice.Status == DanialNetAccount.Models.InvoiceStatus.Active ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                            @invoice.Status
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <a asp-action="Details" asp-route-id="@invoice.Id" class="text-blue-600 hover:text-blue-900 font-medium transition flex items-center justify-end">
                            View
                            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
