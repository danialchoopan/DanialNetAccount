@model DanialNetAccount.Models.Account

<li class="group">
    <div class="flex items-center px-6 py-4 hover:bg-gray-50 transition">
        <div class="mr-4 flex items-center">
            @if (Model.Children != null && Model.Children.Any())
            {
                <button class="toggle-children text-gray-400 hover:text-blue-600 transition p-1">
                    <svg class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            }
            else
            {
                <div class="w-7"></div>
            }
        </div>

        <div class="flex-1 flex justify-between items-center">
            <div>
                <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mr-2">@Model.Code</span>
                <a asp-controller="Report" asp-action="AccountLedger" asp-route-id="@Model.Id" class="text-lg font-semibold text-gray-800 hover:text-blue-600">@Model.Name</a>
            </div>

            <div class="flex items-center space-x-4">
                <span class="px-3 py-1 text-xs font-medium rounded-full
                    @(Model.Type == DanialNetAccount.Models.Enums.AccountType.Asset ? "bg-green-100 text-green-700" :
                      Model.Type == DanialNetAccount.Models.Enums.AccountType.Liability ? "bg-red-100 text-red-700" :
                      Model.Type == DanialNetAccount.Models.Enums.AccountType.Equity ? "bg-purple-100 text-purple-700" :
                      Model.Type == DanialNetAccount.Models.Enums.AccountType.Revenue ? "bg-blue-100 text-blue-700" : "bg-orange-100 text-orange-700")">
                    @Model.Type
                </span>
            </div>
        </div>
    </div>

    @if (Model.Children != null && Model.Children.Any())
    {
        <ul class="hidden border-l-2 border-gray-100 ml-10 mb-2">
            @foreach (var child in Model.Children.OrderBy(c => c.Code))
            {
                @await Html.PartialAsync("_AccountNode", child)
            }
        </ul>
    }
</li>
