@using DanialNetAccount.Services
@inject LocalizationService Loc

<!DOCTYPE html>
<html lang="@(Loc.GetDirection() == "rtl" ? "fa" : "en")" dir="@Loc.GetDirection()">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DanialNet Account</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet" type="text/css" />
    <style>
        body { font-family: Vazirmatn, sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <header class="bg-white border-b no-print">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex">
                    <div class="flex-shrink-0 flex items-center">
                        <a asp-controller="Home" asp-action="Index" class="text-xl font-bold text-blue-600">DanialNet Account</a>
                    </div>
                    <div class="hidden sm:-my-px sm:ml-6 sm:flex sm:space-x-8">
                        <a asp-controller="Account" asp-action="Index" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">@Loc.Translate("Accounts")</a>
                        <a asp-controller="Journal" asp-action="Index" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">@Loc.Translate("Journal")</a>
                        <a asp-controller="Invoice" asp-action="Index" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">@Loc.Translate("Invoices")</a>

                        <div class="relative inline-block text-left group pt-1">
                            <button type="button" class="border-transparent text-gray-500 group-hover:text-gray-700 inline-flex items-center px-1 pt-4 border-b-2 text-sm font-medium">
                                @Loc.Translate("Reports")
                                <svg class="ml-2 -mr-0.5 h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                            </button>
                            <div class="hidden group-hover:block absolute z-10 -ml-4 mt-0 transform px-2 w-48 sm:px-0 lg:ml-0 lg:left-1/2 lg:-translate-x-1/2">
                                <div class="rounded-lg shadow-lg ring-1 ring-black ring-opacity-5 overflow-hidden bg-white">
                                    <div class="relative grid gap-1 px-2 py-2">
                                        <a asp-controller="Report" asp-action="TrialBalance" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded">@Loc.Translate("Trial Balance")</a>
                                        <a asp-controller="Report" asp-action="ProfitLoss" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded">@Loc.Translate("Profit & Loss")</a>
                                        <a asp-controller="Report" asp-action="BalanceSheet" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 rounded">@Loc.Translate("Balance Sheet")</a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <a asp-controller="Settings" asp-action="Index" class="border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">@Loc.Translate("Settings")</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        @RenderBody()
    </main>

    <footer class="bg-white border-t mt-auto no-print">
        <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8 text-center text-gray-500 text-sm">
            &copy; 2025 DanialNet Account - Enterprise Financial Management
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
