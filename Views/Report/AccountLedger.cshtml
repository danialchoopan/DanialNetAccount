@model DanialNetAccount.ViewModels.AccountLedgerViewModel

@{
    ViewData["Title"] = $"Ledger - {Model.AccountName}";
}

<h1>Account Ledger: @Model.AccountName (@Model.AccountCode)</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" class="form-inline">
            <input type="hidden" name="id" value="@Model.AccountId" />
            <div class="form-group mr-2">
                <label class="mr-2">From:</label>
                <input type="date" name="fromDate" class="form-control" />
            </div>
            <div class="form-group mr-2">
                <label class="mr-2">To:</label>
                <input type="date" name="toDate" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>
</div>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Debit</th>
            <th>Credit</th>
            <th>Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var line in Model.Lines)
        {
            <tr>
                <td>@line.Date.ToShortDateString()</td>
                <td>@line.Description</td>
                <td>@line.Debit.ToString("N2")</td>
                <td>@line.Credit.ToString("N2")</td>
                <td class="font-weight-bold">@line.RunningBalance.ToString("N2")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr class="table-secondary">
            <th colspan="4">Closing Balance</th>
            <th>@Model.ClosingBalance.ToString("N2")</th>
        </tr>
    </tfoot>
</table>

<a asp-controller="Account" asp-action="Index" class="btn btn-link">Back to Accounts</a>
