@using DanialNetAccount.Services
@inject LocalizationService Loc
@model DanialNetAccount.ViewModels.InvoiceViewModel

@{
    ViewData["Title"] = Loc.Translate("New Invoice");
    var products = ViewBag.Products as List<DanialNetAccount.Models.Product>;
}

<div class="max-w-5xl mx-auto">
    <div class="flex items-center @(Loc.GetDirection() == "rtl" ? "space-x-reverse" : "space-x-4") mb-8">
        <div class="p-3 @(Model.Type == DanialNetAccount.Models.InvoiceType.Sale ? "bg-green-600" : "bg-blue-600") rounded-2xl text-white shadow-lg">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">@(Model.Type == DanialNetAccount.Models.InvoiceType.Sale ? Loc.Translate("New Invoice") : Loc.Translate("New Purchase Invoice"))</h1>
    </div>

    <form asp-action="Create" id="invoiceForm" class="bg-white shadow-sm border border-gray-100 rounded-2xl p-8">
        <input type="hidden" asp-for="Type" />
        <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-700 p-4 rounded-xl mb-6 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
            <div>
                <label asp-for="CustomerName" class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">@(Model.Type == DanialNetAccount.Models.InvoiceType.Sale ? Loc.Translate("Customer") : Loc.Translate("Vendor Name"))</label>
                <input asp-for="CustomerName" class="block w-full border-gray-200 rounded-xl py-3 px-4 bg-gray-50 border focus:ring-2 focus:ring-blue-500 transition" placeholder="e.g. Acme Corp" />
            </div>
            <div>
                <label asp-for="Date" class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">@Loc.Translate("Date")</label>
                <input asp-for="Date" class="block w-full border-gray-200 rounded-xl py-3 px-4 bg-gray-50 border focus:ring-2 focus:ring-blue-500 transition" type="date" />
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full mb-8" id="itemsTable">
                <thead>
                    <tr class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest border-b border-gray-100">
                        <th class="pb-4 w-1/3 text-center">@Loc.Translate("Product / Service")</th>
                        <th class="pb-4 w-24 text-center">@Loc.Translate("Qty")</th>
                        <th class="pb-4 text-right">@Loc.Translate("Unit Price")</th>
                        <th class="pb-4 text-right">@Loc.Translate("Line Total")</th>
                        <th class="pb-4"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        <tr class="item-row group">
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")">
                                <select name="Items[@i].ProductId" class="block w-full border-gray-200 rounded-xl py-2 bg-gray-50 border product-select">
                                    @foreach (var p in products!)
                                    {
                                        <option value="@p.Id" data-price="@p.Price">@p.Name</option>
                                    }
                                </select>
                            </td>
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Items[@i].Quantity" class="block w-full border-gray-200 rounded-xl py-2 quantity-input text-center bg-gray-50 border" value="@Model.Items[i].Quantity" type="number" /></td>
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Items[@i].UnitPrice" class="block w-full border-gray-200 rounded-xl py-2 price-input text-right font-mono bg-gray-50 border" value="@Model.Items[i].UnitPrice" type="number" step="0.01" /></td>
                            <td class="py-4 text-right font-mono font-bold text-gray-800 item-total">0.00</td>
                            <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pr-4" : "pl-4") text-right"><button type="button" class="text-gray-300 hover:text-red-500 transition remove-item"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex flex-col md:flex-row justify-between items-start md:items-end">
            <button type="button" id="addItem" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-8 rounded-xl transition flex items-center mb-6 md:mb-0">
                <svg class="w-5 h-5 @(Loc.GetDirection() == "rtl" ? "ml-2" : "mr-2") text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                @Loc.Translate("Add Item")
            </button>

            <div class="w-full md:w-80 bg-gray-50 rounded-2xl p-8 space-y-4">
                <div class="flex justify-between text-sm text-gray-500">
                    <span>@Loc.Translate("Subtotal")</span>
                    <span id="subtotal" class="font-mono">0.00</span>
                </div>
                <div class="flex justify-between text-sm text-gray-500">
                    <span>@Loc.Translate("VAT (9%)")</span>
                    <span id="tax" class="font-mono">0.00</span>
                </div>
                <div class="border-t border-gray-200 pt-4 flex justify-between items-center">
                    <span class="text-lg font-black text-gray-900">@Loc.Translate("Total")</span>
                    <span id="finalTotal" class="text-2xl font-black text-blue-600 font-mono">0.00</span>
                </div>
            </div>
        </div>

        <div class="mt-12 pt-8 border-t border-gray-100 flex justify-end space-x-4 @(Loc.GetDirection() == "rtl" ? "space-x-reverse" : "")">
            <a asp-action="Index" class="text-gray-400 hover:text-gray-600 font-bold py-3 px-8 transition">@Loc.Translate("Cancel")</a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-black py-4 px-12 rounded-2xl shadow-xl transition transform active:scale-95">
                @Loc.Translate("Create & Post Invoice")
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products?.Select(p => new { p.Id, p.Name, p.Price })));

            function calculateTotals() {
                let subtotal = 0;
                $('#itemsTable tbody tr').each(function () {
                    let qty = parseFloat($(this).find('.quantity-input').val()) || 0;
                    let price = parseFloat($(this).find('.price-input').val()) || 0;
                    let total = qty * price;
                    $(this).find('.item-total').text(total.toLocaleString(undefined, {minimumFractionDigits: 2}));
                    subtotal += total;
                });

                let tax = subtotal * 0.09;
                let finalTotal = subtotal + tax;

                $('#subtotal').text(subtotal.toLocaleString(undefined, {minimumFractionDigits: 2}));
                $('#tax').text(tax.toLocaleString(undefined, {minimumFractionDigits: 2}));
                $('#finalTotal').text(finalTotal.toLocaleString(undefined, {minimumFractionDigits: 2}));
            }

            $('#addItem').click(function () {
                let index = $('#itemsTable tbody tr').length;
                let options = products.map(p => `<option value="${p.Id}" data-price="${p.Price}">${p.Name}</option>`).join('');
                let row = `
                    <tr class="item-row group">
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")">
                            <select name="Items[${index}].ProductId" class="block w-full border-gray-200 rounded-xl py-2 bg-gray-50 border product-select">
                                ${options}
                            </select>
                        </td>
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Items[${index}].Quantity" class="block w-full border-gray-200 rounded-xl py-2 quantity-input text-center bg-gray-50 border" value="1" type="number" /></td>
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pl-4" : "pr-4")"><input name="Items[${index}].UnitPrice" class="block w-full border-gray-200 rounded-xl py-2 price-input text-right font-mono bg-gray-50 border" value="${products[0]?.Price || 0}" type="number" step="0.01" /></td>
                        <td class="py-4 text-right font-mono font-bold text-gray-800 item-total">0.00</td>
                        <td class="py-4 @(Loc.GetDirection() == "rtl" ? "pr-4" : "pl-4") text-right"><button type="button" class="text-gray-300 hover:text-red-500 transition remove-item"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                    </tr>`;
                $('#itemsTable tbody').append(row);
                calculateTotals();
            });

            $(document).on('click', '.remove-item', function () {
                $(this).closest('tr').remove();
                reindexItems();
                calculateTotals();
            });

            $(document).on('change', '.product-select', function() {
                let price = $(this).find(':selected').data('price');
                $(this).closest('tr').find('.price-input').val(price);
                calculateTotals();
            });

            $(document).on('input', '.quantity-input, .price-input', function () {
                calculateTotals();
            });

            function reindexItems() {
                $('#itemsTable tbody tr').each(function (index) {
                    $(this).find('.product-select').attr('name', `Items[${index}].ProductId`);
                    $(this).find('.quantity-input').attr('name', `Items[${index}].Quantity`);
                    $(this).find('.price-input').attr('name', `Items[${index}].UnitPrice`);
                });
            }

            if($('#itemsTable tbody tr').length === 0) {
                $('#addItem').click();
            }
            calculateTotals();
        });
    </script>
}
