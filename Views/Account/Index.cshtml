@model IEnumerable<DanialNetAccount.Models.Account>

@{
    ViewData["Title"] = "Chart of Accounts";
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Chart of Accounts</h1>
    <a asp-action="Create" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg shadow-sm transition">
        Create New Account
    </a>
</div>

<div class="bg-white shadow-sm border border-gray-100 rounded-xl overflow-hidden">
    <ul class="divide-y divide-gray-100">
        @foreach (var account in Model)
        {
            @await Html.PartialAsync("_AccountNode", account)
        }
    </ul>
</div>

@section Scripts {
    <script>
        $(document).on('click', '.toggle-children', function() {
            $(this).parent().siblings('ul').toggleClass('hidden');
            let svg = $(this).find('svg');
            svg.toggleClass('rotate-90');
        });
    </script>
}
