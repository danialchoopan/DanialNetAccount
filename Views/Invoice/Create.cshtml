@model DanialNetAccount.ViewModels.InvoiceViewModel

@{
    ViewData["Title"] = "New Invoice";
    var products = ViewBag.Products as List<DanialNetAccount.Models.Product>;
}

<div class="max-w-5xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">New Invoice</h1>

    <form asp-action="Create" id="invoiceForm" class="bg-white shadow-sm border border-gray-100 rounded-xl p-8">
        <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-700 p-4 rounded-lg mb-6 text-sm"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
            <div>
                <label asp-for="CustomerName" class="block text-sm font-medium text-gray-700 mb-2">Customer Name</label>
                <input asp-for="CustomerName" class="block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2.5 px-4 bg-gray-50 border" placeholder="Client or Cash Customer" />
            </div>
            <div>
                <label asp-for="Date" class="block text-sm font-medium text-gray-700 mb-2">Invoice Date</label>
                <input asp-for="Date" class="block w-full border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 py-2.5 px-4 bg-gray-50 border" type="date" />
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full mb-8" id="itemsTable">
                <thead>
                    <tr class="text-left text-sm font-semibold text-gray-500 border-b border-gray-100">
                        <th class="pb-4 w-1/3">Product / Service</th>
                        <th class="pb-4 w-20">Qty</th>
                        <th class="pb-4 text-right">Unit Price</th>
                        <th class="pb-4 text-right">Line Total</th>
                        <th class="pb-4"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        <tr class="item-row">
                            <td class="py-4 pr-4">
                                <select name="Items[@i].ProductId" class="block w-full border-gray-300 rounded-lg py-2 product-select bg-gray-50 border">
                                    @foreach (var p in products!)
                                    {
                                        <option value="@p.Id" data-price="@p.Price">@p.Name</option>
                                    }
                                </select>
                            </td>
                            <td class="py-4 pr-4"><input name="Items[@i].Quantity" class="block w-full border-gray-300 rounded-lg py-2 quantity-input text-center bg-gray-50 border" value="@Model.Items[i].Quantity" type="number" /></td>
                            <td class="py-4 pr-4"><input name="Items[@i].UnitPrice" class="block w-full border-gray-300 rounded-lg py-2 price-input text-right font-mono bg-gray-50 border" value="@Model.Items[i].UnitPrice" type="number" step="0.01" /></td>
                            <td class="py-4 text-right font-mono font-bold text-gray-800 item-total">0.00</td>
                            <td class="py-4 pl-4 text-right"><button type="button" class="text-red-500 hover:text-red-700 transition remove-item"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex flex-col md:flex-row justify-between items-start md:items-end">
            <button type="button" id="addItem" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-6 rounded-lg transition flex items-center mb-6 md:mb-0">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Add Item
            </button>

            <div class="w-full md:w-80 bg-gray-50 rounded-xl p-6 space-y-4">
                <div class="flex justify-between text-sm text-gray-500">
                    <span>Subtotal</span>
                    <span id="subtotal" class="font-mono">$0.00</span>
                </div>
                <div class="flex justify-between text-sm text-gray-500">
                    <span>VAT (9%)</span>
                    <span id="tax" class="font-mono">$0.00</span>
                </div>
                <div class="border-t border-gray-200 pt-4 flex justify-between items-center">
                    <span class="text-lg font-bold text-gray-900">Total</span>
                    <span id="finalTotal" class="text-2xl font-bold text-blue-600 font-mono">$0.00</span>
                </div>
            </div>
        </div>

        <div class="mt-10 pt-8 border-t border-gray-100 flex justify-end space-x-4">
            <a asp-action="Index" class="text-gray-500 hover:text-gray-700 font-medium py-2.5 px-6">Back to List</a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-10 rounded-lg shadow-lg transition">Create & Post Invoice</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products?.Select(p => new { p.Id, p.Name, p.Price })));

            function calculateTotals() {
                let subtotal = 0;
                $('#itemsTable tbody tr').each(function () {
                    let qty = parseFloat($(this).find('.quantity-input').val()) || 0;
                    let price = parseFloat($(this).find('.price-input').val()) || 0;
                    let total = qty * price;
                    $(this).find('.item-total').text(total.toLocaleString(undefined, {minimumFractionDigits: 2}));
                    subtotal += total;
                });

                let tax = subtotal * 0.09;
                let finalTotal = subtotal + tax;

                $('#subtotal').text(subtotal.toLocaleString(undefined, {style: 'currency', currency: 'USD'}));
                $('#tax').text(tax.toLocaleString(undefined, {style: 'currency', currency: 'USD'}));
                $('#finalTotal').text(finalTotal.toLocaleString(undefined, {style: 'currency', currency: 'USD'}));
            }

            $('#addItem').click(function () {
                let index = $('#itemsTable tbody tr').length;
                let options = products.map(p => `<option value="${p.Id}" data-price="${p.Price}">${p.Name}</option>`).join('');
                let row = `
                    <tr class="item-row">
                        <td class="py-4 pr-4">
                            <select name="Items[${index}].ProductId" class="block w-full border-gray-300 rounded-lg py-2 product-select bg-gray-50 border">
                                ${options}
                            </select>
                        </td>
                        <td class="py-4 pr-4"><input name="Items[${index}].Quantity" class="block w-full border-gray-300 rounded-lg py-2 quantity-input text-center bg-gray-50 border" value="1" type="number" /></td>
                        <td class="py-4 pr-4"><input name="Items[${index}].UnitPrice" class="block w-full border-gray-300 rounded-lg py-2 price-input text-right font-mono bg-gray-50 border" value="${products[0]?.Price || 0}" type="number" step="0.01" /></td>
                        <td class="py-4 text-right font-mono font-bold text-gray-800 item-total">0.00</td>
                        <td class="py-4 pl-4 text-right"><button type="button" class="text-red-500 hover:text-red-700 transition remove-item"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button></td>
                    </tr>`;
                $('#itemsTable tbody').append(row);
                calculateTotals();
            });

            $(document).on('click', '.remove-item', function () {
                $(this).closest('tr').remove();
                reindexItems();
                calculateTotals();
            });

            $(document).on('change', '.product-select', function() {
                let price = $(this).find(':selected').data('price');
                $(this).closest('tr').find('.price-input').val(price);
                calculateTotals();
            });

            $(document).on('input', '.quantity-input, .price-input', function () {
                calculateTotals();
            });

            function reindexItems() {
                $('#itemsTable tbody tr').each(function (index) {
                    $(this).find('.product-select').attr('name', `Items[${index}].ProductId`);
                    $(this).find('.quantity-input').attr('name', `Items[${index}].Quantity`);
                    $(this).find('.price-input').attr('name', `Items[${index}].UnitPrice`);
                });
            }

            if($('#itemsTable tbody tr').length === 0) {
                $('#addItem').click();
            }
            calculateTotals();
        });
    </script>
}
